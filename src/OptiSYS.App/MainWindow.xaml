<Window
    x:Class="OptiSYS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:controls="using:OptiSYS.Controls"
    Title="optiSYS">

    

    <Grid x:Name="ShellRoot" Background="Transparent">
        <Grid.Resources>
            <Style x:Key="SidebarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Margin" Value="0,2" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Custom Title Bar -->
            <RowDefinition Height="*" />    <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Height="36" Grid.Row="0" Background="Transparent" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" /> <!-- Caption buttons padding -->
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="8">
                <Image Source="ms-appx:///Assets/AppIcon.png" Width="18" Height="18" VerticalAlignment="Center" />
                <TextBlock Text="optiSYS" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Compatibility TextBlocks required by tests -->
        <TextBlock x:Name="StatusText" Visibility="Collapsed" />
        <TextBlock x:Name="FooterText" Visibility="Collapsed" />

        <!-- Main Workspace Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" /> <!-- Sidebar -->
                <ColumnDefinition Width="*" />   <!-- Content Area -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0" Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Navigation Links -->
                <StackPanel Grid.Row="0" Margin="12,16,12,0" Spacing="4">
                    <!-- Dashboard -->
                    <Button x:Name="DashboardBtn" Click="SidebarBtn_Click" Style="{StaticResource SidebarButtonStyle}" Tag="Dashboard" AutomationProperties.Name="Dashboard">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="DashboardAccentBorder" Width="4" Height="18" Background="{ThemeResource SystemAccentColorBrush}" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-6,0,8,0" Visibility="Visible" />
                            <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="12" Margin="6,0,0,0">
                                <FontIcon Glyph="&#xE80F;" FontSize="16" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Protected Apps -->
                    <Button x:Name="ProtectedAppsBtn" Click="SidebarBtn_Click" Style="{StaticResource SidebarButtonStyle}" Tag="ProtectedApps" AutomationProperties.Name="Protected Applications">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ProtectedAppsAccentBorder" Width="4" Height="18" Background="{ThemeResource SystemAccentColorBrush}" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-6,0,8,0" Visibility="Collapsed" />
                            <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="12" Margin="6,0,0,0">
                                <FontIcon Glyph="&#xE73E;" FontSize="16" />
                                <TextBlock Text="Protected Applications" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Settings -->
                    <Button x:Name="SettingsBtn" Click="SidebarBtn_Click" Style="{StaticResource SidebarButtonStyle}" Tag="Settings" AutomationProperties.Name="Settings">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="SettingsAccentBorder" Width="4" Height="18" Background="{ThemeResource SystemAccentColorBrush}" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-6,0,8,0" Visibility="Collapsed" />
                            <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="12" Margin="6,0,0,0">
                                <FontIcon Glyph="&#xE713;" FontSize="16" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content Area — inset panel with a rounded top-left corner, so the acrylic
                 sidebar + title bar read as one continuous frame around it (Codex / VS Code look). -->
            <Border Grid.Column="1" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" CornerRadius="8,0,0,0">
            <Grid Padding="28,24,28,24">
                
                <!-- ==================== DASHBOARD TAB ==================== -->
                <ScrollViewer x:Name="DashboardGrid" Visibility="Visible" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="0,0,0,16">
                        <!-- Dashboard header row with manual-optimize + pause actions -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="System Dashboard" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button x:Name="ManualTrimButton" Style="{StaticResource AccentButtonStyle}" Click="OnManualTrimClick" Width="40" Height="40" Padding="0" CornerRadius="4" VerticalAlignment="Center" ToolTipService.ToolTip="Optimize now" AutomationProperties.Name="Optimize now">
                                    <FontIcon Glyph="&#xE768;" FontSize="16" />
                                </Button>
                                <Button x:Name="PauseToggleButton" Click="OnToggleProtectionClick" Width="40" Height="40" Padding="0" CornerRadius="4" VerticalAlignment="Center" ToolTipService.ToolTip="Pause optimization" AutomationProperties.Name="Pause optimization">
                                    <FontIcon x:Name="PauseToggleIcon" Glyph="&#xE769;" FontSize="16" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Live Telemetry Card Row -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Memory Card -->
                            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE964;" FontSize="16" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="Memory Health" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel x:Name="MemoryPausedIndicator" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                                            <FontIcon Glyph="&#xE769;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="Paused" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="MemoryPercentText" Text="--%" Style="{StaticResource HeaderTextBlockStyle}" FontWeight="Bold" />
                                        <TextBlock x:Name="MemoryGBText" Text="-- GB / -- GB" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ProgressBar x:Name="MemoryProgressBar" AutomationProperties.Name="Memory usage percentage" Minimum="0" Maximum="100" Value="0" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" Foreground="{ThemeResource SystemAccentColorBrush}" Height="6" CornerRadius="3" />
                                    <Grid ColumnSpacing="8" RowSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE753;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Cached &amp; Standby" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="MemoryCachedText" Grid.Row="0" Grid.Column="1" Text="-- GB" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        
                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE902;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Active Processes" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="MemoryProcessesText" Grid.Row="1" Grid.Column="1" Text="--" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Memory optimization mode -->
                                    <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Mode" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <ComboBox x:Name="OptimizationLevelComboBox" Grid.Column="1" MinWidth="140" VerticalAlignment="Center" SelectionChanged="OnSettingsChanged">
                                            <ComboBoxItem Content="Normal" />
                                            <ComboBoxItem Content="Balanced" />
                                            <ComboBoxItem Content="Max" />
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Battery / Power Card -->
                            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon x:Name="PowerIcon" Glyph="&#xE83F;" FontSize="16" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="Efficiency" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel x:Name="EfficiencyPausedIndicator" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                                            <FontIcon Glyph="&#xE769;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="Paused" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="BatteryPercentText" Text="AC" Style="{StaticResource HeaderTextBlockStyle}" FontWeight="Bold" />
                                        <TextBlock x:Name="BatterySourceText" Text="Connected to power" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ProgressBar x:Name="BatteryProgressBar" AutomationProperties.Name="Battery charge percentage" Minimum="0" Maximum="100" Value="100" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" Foreground="{ThemeResource SystemAccentColorBrush}" Height="6" CornerRadius="3" />
                                    <Grid ColumnSpacing="8" RowSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xEC4E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Power Drain Rate" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="BatteryDrainText" Grid.Row="0" Grid.Column="1" Text="N/A" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        
                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xEC92;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Estimated Remaining" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="BatteryRemainingText" Grid.Row="1" Grid.Column="1" Text="N/A" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Battery care profile -->
                                    <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Profile" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <ComboBox x:Name="BatteryPresetComboBox" Grid.Column="1" MinWidth="140" VerticalAlignment="Center" SelectionChanged="OnBatteryPresetChanged">
                                            <ComboBoxItem Content="Recommended" />
                                            <ComboBoxItem Content="Saver" />
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Memory Usage Trend Chart Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <TextBlock Text="Memory Usage History" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                        <Ellipse Width="8" Height="8" Fill="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="Live Telemetry" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemAccentColorBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                
                                <controls:HistoryChartControl x:Name="MemoryHistoryChart" />
                                <Grid>
                                    <TextBlock Text="Last 40 samples (5s interval)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="DPI-Scaled Vector Rendering" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>


                <!-- ==================== PROTECTED APPLICATIONS TAB ==================== -->
                <ScrollViewer x:Name="ProtectedAppsGrid" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" MaxWidth="760" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <TextBlock Text="Protected Applications" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="These critical applications are fully excluded from all resource trimming, EcoQoS scheduling, and background thread restrictions. Protect your development tools, browsers, or active workspaces here." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                        <Grid ColumnSpacing="8" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ProtectedAppInput" PlaceholderText="Process name (e.g., Code)" KeyDown="OnProtectedAppInputKeyDown" />
                            <Button Content="Add" Grid.Column="1" Click="OnAddProtectedAppClick" Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Browse..." Grid.Column="2" Click="OnBrowseProtectedAppClick" />
                        </Grid>

                        <Border Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="4">
                            <ListView x:Name="ProtectedAppsListView" MinHeight="200" MaxHeight="520" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,4" Padding="12,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource SystemAccentColorBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold" />
                                                <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe Fluent Icons" Background="Transparent" BorderThickness="0" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Click="OnRemoveProtectedAppClick" CommandParameter="{Binding}" AutomationProperties.Name="{Binding}" ToolTipService.ToolTip="Remove" Padding="8,4" VerticalAlignment="Center">
                                                    <Button.Resources>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource SystemFillColorCriticalBackground}" />
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ==================== SETTINGS TAB ==================== -->
                <ScrollViewer x:Name="SettingsGrid" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,4" />

                        <TextBlock Text="Optimization" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- The single master switch. Everything else (memory tuning, predictive
                             trimming, Wi-Fi latency, efficiency-follows-power) runs under the hood. -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE7E8;" FontSize="20" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Automatic optimization" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Keeps your PC fast and efficient in the background — frees memory under pressure and reduces Wi-Fi latency. Fully automatic and reversible; nothing to configure." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="AutomaticOptimizationToggle" Grid.Column="2" IsOn="True" Toggled="OnAutomaticOptimizationToggled" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <TextBlock Text="General App settings" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- Start optiSYS with Windows Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE7F4;" FontSize="20" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Start optiSYS with Windows" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Automatically launch in the background when logging into Windows." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="StartWithWindowsToggle" Grid.Column="2" IsOn="True" Toggled="OnStartWithWindowsToggled" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Minimize to System Tray Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE70F;" FontSize="20" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Minimize to System Tray" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Closing the app window keeps it running in the taskbar tray." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="MinimizeToTrayToggle" Grid.Column="2" IsOn="True" Toggled="OnSettingsChanged" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <TextBlock Text="System Tools &amp; Maintenance" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0" />

                        <!-- Deep Clean Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xEA99;" FontSize="20" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Deep clean (free up memory)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Aggressively reclaims standby cache and working sets. Can briefly cause disk activity or a short stutter — use before a memory-heavy task." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Button x:Name="DeepCleanButton" Content="Deep clean" Grid.Column="2" Click="OnDeepCleanClick" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Reset Configuration Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE77C;" FontSize="20" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Reset Configuration" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Reset all settings, exclusions, thresholds and timer configs to factory defaults." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Button Content="Reset Settings to Defaults" Grid.Column="2" Click="OnResetSettingsClick" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- About optiSYS Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <Grid>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="optiSYS Optimizer Suite" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock x:Name="AppVersionText" Text="Version 0.0.3 // Active System Protection" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="Developed by eptesicus" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <FontIcon Glyph="&#xE964;" FontSize="40" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.1" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
