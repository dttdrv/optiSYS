<Window
    x:Class="OptiSYS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:controls="using:OptiSYS.Controls"
    Title="optiSYS">

    

    <Grid x:Name="ShellRoot" Background="Transparent">
        <Grid.Resources>
            <!-- Compact, Win11-Settings-style nav item: ~36px row, 4px corner. Hover / pressed /
                 selected are driven entirely by the template's VisualStateManager off standard
                 Fluent theme brushes (no code-set Background). There is intentionally NO Pressed
                 RenderTransform / PointerDownThemeAnimation, so clicking never "bounces". The
                 accent selection pill is a single shared indicator that slides between rows
                 (see NavIndicator below), not a per-item border. -->
            <Style x:Key="SidebarButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="11,0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Margin" Value="0,1" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid"
                                  Background="Transparent"
                                  CornerRadius="{TemplateBinding CornerRadius}">
                                <Border x:Name="BackgroundBorder"
                                        Background="Transparent"
                                        CornerRadius="{TemplateBinding CornerRadius}" />
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Padding="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                                <VisualStateManager.VisualStateGroups>
                                    <!-- Hover / pressed background only. No scale transform -> no bounce.
                                         Selection is shown by the shared sliding NavIndicator, plus a
                                         persistent subtle fill applied via the SelectionStates group. -->
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundBorder" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorDisabledBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <!-- Selected = persistent subtle fill. Driven from code via
                                         VisualStateManager.GoToState (a state, not a code-set Background). -->
                                    <VisualStateGroup x:Name="SelectionStates">
                                        <VisualState x:Name="Unselected" />
                                        <VisualState x:Name="Selected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Custom Title Bar -->
            <RowDefinition Height="*" />    <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- Backdrop fallback: a theme-grey layer behind everything, shown only when there is no
             translucent system backdrop (battery saver / elevated window / "None") so the sidebar +
             title bar don't read near-black. Toggled by ThemeManager.ApplyBackdrop. -->
        <Border x:Name="BackdropFallback" Grid.Row="0" Grid.RowSpan="2"
                Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}" Visibility="Collapsed" />

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Height="36" Grid.Row="0" Background="Transparent" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" /> <!-- Caption buttons padding -->
            </Grid.ColumnDefinitions>

            <!-- Intentionally empty: Windows apps don't render their icon/title in the window's
                 top-left content. This strip stays the draggable region (SetTitleBar); the system
                 caption buttons sit at the right. Branding lives in the sidebar footer. -->

        </Grid>

        <!-- Compatibility TextBlocks required by tests -->
        <TextBlock x:Name="StatusText" Visibility="Collapsed" />
        <TextBlock x:Name="FooterText" Visibility="Collapsed" />

        <!-- Main Workspace Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" /> <!-- Sidebar (-15%) -->
                <ColumnDefinition Width="*" />   <!-- Content Area -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Navigation Links. The single shared accent indicator (NavIndicator) overlays
                     the item list and slides between rows via its TranslateTransform.Y (animated in
                     code on selection change). The items themselves no longer carry per-item pills. -->
                <Grid Grid.Row="0" Margin="8,4,8,0">
                    <!-- 3px accent selection pill, 16px tall, left edge. Y is set/animated in code. -->
                    <Border x:Name="NavIndicator" Width="3" Height="16"
                            Background="{ThemeResource SystemAccentColorBrush}" CornerRadius="1.5"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1,0,0,0"
                            IsHitTestVisible="False">
                        <Border.RenderTransform>
                            <!-- Y defaults to the Dashboard row (NavIndicatorRow0Y) so the first
                                 paint is correct; selection changes animate Y in code-behind. -->
                            <TranslateTransform x:Name="NavIndicatorTransform" Y="11" />
                        </Border.RenderTransform>
                    </Border>

                    <StackPanel Spacing="2">
                        <!-- Dashboard -->
                        <Button x:Name="DashboardBtn" Click="SidebarBtn_Click" Style="{StaticResource SidebarButtonStyle}" Tag="Dashboard" AutomationProperties.Name="Dashboard">
                            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center" Margin="5,0,0,0">
                                <FontIcon Glyph="&#xE80F;" FontSize="16" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Settings -->
                        <Button x:Name="SettingsBtn" Click="SidebarBtn_Click" Style="{StaticResource SidebarButtonStyle}" Tag="Settings" AutomationProperties.Name="Settings">
                            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center" Margin="5,0,0,0">
                                <FontIcon Glyph="&#xE713;" FontSize="16" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- About (bottom-left): brand wordmark + compact author/repo links. The person icon
                     links to the author's site; the GitHub icon + accent dot + version are a single
                     hyperlink to the repo. -->
                <StackPanel Grid.Row="1" Margin="12,0,12,14" Spacing="2">
                    <TextBlock Text="optiSYS" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <HyperlinkButton NavigateUri="https://dttdrv.xyz" Padding="4,2" MinWidth="0" MinHeight="0"
                                         ToolTipService.ToolTip="Deyan Todorov" AutomationProperties.Name="Deyan Todorov">
                            <FontIcon Glyph="&#xE77B;" FontSize="15" Foreground="{ThemeResource SystemAccentColorBrush}" />
                        </HyperlinkButton>
                        <HyperlinkButton NavigateUri="https://github.com/dttdrv/optiSYS" Padding="4,2" MinWidth="0" MinHeight="0"
                                         ToolTipService.ToolTip="optiSYS on GitHub" AutomationProperties.Name="optiSYS on GitHub">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{ThemeResource SystemAccentColorBrush}"
                                      Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                                <TextBlock Text="&#x2022;" FontSize="14" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="AppVersionText" Text="1.0.0-alpha.1" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </HyperlinkButton>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Main Content Area — inset panel with a rounded top-left corner, so the acrylic
                 sidebar + title bar read as one continuous frame around it (Codex / VS Code look). -->
            <Border Grid.Column="1" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" CornerRadius="8,0,0,8">
            <Grid Padding="28,24,28,24">
                
                <!-- ==================== DASHBOARD TAB ==================== -->
                <Grid x:Name="DashboardGrid" Visibility="Visible">

                    <!-- Fixed header band: declared FIRST so the title + action buttons come first in
                         tab / Narrator order, and raised with Canvas.ZIndex so it still paints ON TOP
                         of the scroller. Its opaque base fill matches the content panel, so scrolled
                         content disappears cleanly under it; the right margin leaves the scrollbar
                         gutter free. Its height drives the body's top inset from code-behind
                         (OnDashboardHeaderSizeChanged), so there is no hardcoded clearance to drift. -->
                    <Grid x:Name="DashboardHeader" Canvas.ZIndex="1" VerticalAlignment="Top"
                          Margin="0,0,12,0" Padding="0,0,0,16"
                          Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                          SizeChanged="OnDashboardHeaderSizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="System Dashboard" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button x:Name="ManualTrimButton" Style="{StaticResource AccentButtonStyle}" Click="OnManualTrimClick" Width="40" Height="40" Padding="0" CornerRadius="4" VerticalAlignment="Center" ToolTipService.ToolTip="Optimize now" AutomationProperties.Name="Optimize now">
                                <FontIcon Glyph="&#xE768;" FontSize="16" />
                            </Button>
                            <Button x:Name="PauseToggleButton" Click="OnToggleProtectionClick" Width="40" Height="40" Padding="0" CornerRadius="4" VerticalAlignment="Center" ToolTipService.ToolTip="Pause optimization" AutomationProperties.Name="Pause optimization">
                                <FontIcon x:Name="PauseToggleIcon" Glyph="&#xE769;" FontSize="16" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                        <StackPanel x:Name="DashboardBody" Spacing="16" Margin="0,56,0,16">

                        <!-- Live Telemetry Card Row -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Memory Card -->
                            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xE964;" FontSize="16" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="Memory" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel x:Name="MemoryPausedIndicator" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xE769;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="Paused" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="MemoryPercentText" Text="--%" Style="{StaticResource HeaderTextBlockStyle}" FontWeight="Bold" />
                                        <TextBlock x:Name="MemoryGBText" Text="-- GB / -- GB" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ProgressBar x:Name="MemoryProgressBar" AutomationProperties.Name="Memory usage percentage" Minimum="0" Maximum="100" Value="0" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" Foreground="{ThemeResource SystemAccentColorBrush}" Height="6" CornerRadius="3" />
                                    <Grid ColumnSpacing="8" RowSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xE753;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Cached &amp; Standby" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="MemoryCachedText" Grid.Row="0" Grid.Column="1" Text="-- GB" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />

                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xE902;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Active Processes" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="MemoryProcessesText" Grid.Row="1" Grid.Column="1" Text="--" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />

                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xEA99;" FontSize="12" Foreground="{ThemeResource SystemAccentColorBrush}" />
                                            <TextBlock Text="Freed this session" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="MemoryClearedText" Grid.Row="2" Grid.Column="1" Text="0 MB" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Memory optimization mode -->
                                    <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Mode" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <ComboBox x:Name="OptimizationLevelComboBox" Grid.Column="1" MinWidth="140" VerticalAlignment="Center" SelectionChanged="OnSettingsChanged" AutomationProperties.Name="Memory optimization mode">
                                            <ComboBoxItem Content="Balanced" />
                                            <ComboBoxItem Content="Max" />
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Battery / Power Card -->
                            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <StackPanel Spacing="16">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" x:Name="PowerIcon" Glyph="&#xE83F;" FontSize="16" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="Efficiency" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel x:Name="EfficiencyPausedIndicator" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xE769;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="Paused" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="BatteryPercentText" Text="AC" Style="{StaticResource HeaderTextBlockStyle}" FontWeight="Bold" />
                                        <TextBlock x:Name="BatterySourceText" Text="Connected to power" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ProgressBar x:Name="BatteryProgressBar" AutomationProperties.Name="Battery charge percentage" Minimum="0" Maximum="100" Value="100" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" Foreground="{ThemeResource SystemAccentColorBrush}" Height="6" CornerRadius="3" />
                                    <Grid ColumnSpacing="8" RowSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xEC4E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Power Drain Rate" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="BatteryDrainText" Grid.Row="0" Grid.Column="1" Text="N/A" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        
                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xEC92;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Estimated Remaining" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock x:Name="BatteryRemainingText" Grid.Row="1" Grid.Column="1" Text="N/A" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Memory Usage Trend Chart Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Memory Usage History" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <controls:HistoryChartControl x:Name="MemoryHistoryChart" AutomationProperties.Name="Memory usage history chart" />
                            </StackPanel>
                        </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>


                <!-- ==================== SETTINGS TAB ==================== -->
                <ScrollViewer x:Name="SettingsGrid" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                    <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,4" />

                        <TextBlock Text="Optimization" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- The single master switch. Everything else (memory tuning, predictive
                             trimming, Wi-Fi latency, efficiency-follows-power) runs under the hood. -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xE7E8;" FontSize="20" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Automatic optimization" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Keeps your PC fast and efficient in the background — frees memory under pressure and reduces Wi-Fi latency. Fully automatic and reversible; nothing to configure." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="AutomaticOptimizationToggle" Grid.Column="2" IsOn="True" Toggled="OnAutomaticOptimizationToggled" VerticalAlignment="Center" MinWidth="0" HorizontalAlignment="Right" AutomationProperties.Name="Automatic optimization" />
                            </Grid>
                        </Border>

                        <TextBlock Text="General App settings" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- Start optiSYS with Windows Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xE7F4;" FontSize="20" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Start optiSYS with Windows" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Automatically launch in the background when logging into Windows." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="StartWithWindowsToggle" Grid.Column="2" IsOn="True" Toggled="OnStartWithWindowsToggled" VerticalAlignment="Center" MinWidth="0" HorizontalAlignment="Right" AutomationProperties.Name="Start optiSYS with Windows" />
                            </Grid>
                        </Border>

                        <!-- Minimize to System Tray Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon AutomationProperties.AccessibilityView="Raw" Glyph="&#xE70F;" FontSize="20" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Minimize to System Tray" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Closing the app window keeps it running in the taskbar tray." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="MinimizeToTrayToggle" Grid.Column="2" IsOn="True" Toggled="OnSettingsChanged" VerticalAlignment="Center" MinWidth="0" HorizontalAlignment="Right" AutomationProperties.Name="Minimize to system tray" />
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        </Grid>

        <!-- ==================== FIRST-RUN ONBOARDING OVERLAY ====================
             Full-window layer shown on first launch (HasCompletedOnboarding=false). Uses the same
             Visibility-toggle pattern as the Dashboard/Settings tabs (no ContentDialog/NavigationView)
             to stay clear of the unconfirmed Microsoft.UI.Xaml fail-fast class. Stepped: one feature
             per panel, driven from code-behind over OnboardingState. -->
        <Grid x:Name="OnboardingOverlay" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <Border MaxWidth="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="32,28">
                <StackPanel Spacing="20" MinWidth="360">
                    <!-- Icon stays fixed; only the step host fades/slides between steps. -->
                    <Image x:Name="OnboardingIcon" Width="40" Height="40" HorizontalAlignment="Center" />

                    <!-- Animatable step host: the 5 panels overlap (only one visible at a time);
                         a fade+slide Storyboard runs on this host's Opacity + TranslateTransform.X. -->
                    <Grid x:Name="OnboardingStepHost">
                        <Grid.RenderTransform>
                            <TranslateTransform />
                        </Grid.RenderTransform>

                        <!-- Welcome -->
                        <StackPanel x:Name="StepWelcome" Spacing="8" Visibility="Visible">
                            <TextBlock Text="Welcome to optiSYS" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="optiSYS keeps your PC fast and efficient — automatically, and fully reversibly. Let's pick what it should help with." TextWrapping="Wrap" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <!-- Wi-Fi -->
                        <StackPanel x:Name="StepWiFi" Spacing="12" Visibility="Collapsed">
                            <TextBlock Text="Wi-Fi" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="Keeps your connection responsive by stopping background Wi-Fi scans while you're online. Fully reversible — no permanent system changes." TextWrapping="Wrap" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ToggleSwitch x:Name="OnboardWiFiToggle" IsOn="True" HorizontalAlignment="Center" MinWidth="0" OnContent="On" OffContent="Off" />
                        </StackPanel>

                        <!-- Battery -->
                        <StackPanel x:Name="StepBattery" Spacing="12" Visibility="Collapsed">
                            <TextBlock Text="Battery" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="Saves power when you're on battery and steps back the moment you plug in — automatically. Nothing to manage." TextWrapping="Wrap" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ToggleSwitch x:Name="OnboardBatteryToggle" IsOn="True" HorizontalAlignment="Center" MinWidth="0" OnContent="On" OffContent="Off" />
                        </StackPanel>

                        <!-- Memory -->
                        <StackPanel x:Name="StepMemory" Spacing="12" Visibility="Collapsed">
                            <TextBlock Text="Memory" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="Frees up memory when your PC is under pressure. 'Max' reclaims more, more often." TextWrapping="Wrap" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ToggleSwitch x:Name="OnboardMemoryToggle" IsOn="True" HorizontalAlignment="Center" MinWidth="0" OnContent="On" OffContent="Off" />
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <TextBlock Text="Level" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox x:Name="OnboardMemoryLevel" MinWidth="140" SelectedIndex="0">
                                    <ComboBoxItem Content="Balanced" />
                                    <ComboBoxItem Content="Max" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>

                        <!-- Done -->
                        <StackPanel x:Name="StepDone" Spacing="8" Visibility="Collapsed">
                            <TextBlock Text="You're all set" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="optiSYS will work quietly in the background. You can change anything later in Settings." TextWrapping="Wrap" TextAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <!-- Step dots -->
                    <StackPanel x:Name="OnboardingDots" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" />

                    <!-- Navigation -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="OnboardBackButton" Grid.Column="0" Content="Back" Click="OnOnboardingBack" MinWidth="88" />
                        <Button x:Name="OnboardNextButton" Grid.Column="2" Style="{StaticResource AccentButtonStyle}" Content="Next" Click="OnOnboardingNext" MinWidth="88" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
