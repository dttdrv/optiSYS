<Page
    x:Class="OptiSYS.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        ComboBox.SelectedItem is bound directly to the enum-typed VM property. WinUI's
        default enum converter matches on ComboBoxItem.Content (a string) against
        Enum.Parse so "Balanced" round-trips to OptimizationLevel.Balanced without a
        value converter.  Same trick for ThemeMode, which the VM stores as a plain
        string ("System" / "Light" / "Dark").

        Save button disables while clean — rather than adding an InverseBool→Bool converter,
        we bind IsEnabled directly to IsDirty (true=enabled, false=disabled), which is the
        natural shape of the flag.  No converter gymnastics needed.
    -->
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- General -->
            <StackPanel Spacing="8">
                <TextBlock Text="General" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel>
                            <TextBlock Text="Theme" Opacity="0.7" FontSize="12" />
                            <ComboBox ItemsSource="{Binding ThemeModes}"
                                      SelectedItem="{Binding ThemeMode, Mode=TwoWay}"
                                      MinWidth="200" />
                        </StackPanel>
                        <ToggleSwitch Header="Start with Windows"
                                      IsOn="{Binding StartWithWindows, Mode=TwoWay}" />
                        <ToggleSwitch Header="Minimize to tray"
                                      IsOn="{Binding MinimizeToTray, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Auto-optimization -->
            <StackPanel Spacing="8">
                <TextBlock Text="Auto-optimization" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <ToggleSwitch Header="Auto-optimize on battery"
                                      IsOn="{Binding AutoOptimizeOnBattery, Mode=TwoWay}" />
                        <ToggleSwitch Header="Auto-optimize memory"
                                      IsOn="{Binding AutoOptimizeMemoryEnabled, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Battery domains -->
            <StackPanel Spacing="8">
                <TextBlock Text="Battery domains" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="10">
                        <ToggleSwitch Header="EcoQoS scheduler"
                                      IsOn="{Binding EcoQosEnabled, Mode=TwoWay}" />
                        <ToggleSwitch Header="Timer resolution (1ms → 15.6ms)"
                                      IsOn="{Binding TimerResolutionEnabled, Mode=TwoWay}" />
                        <ToggleSwitch Header="Background services throttle"
                                      IsOn="{Binding BackgroundServicesEnabled, Mode=TwoWay}" />
                        <ToggleSwitch Header="USB selective suspend"
                                      IsOn="{Binding UsbSuspendEnabled, Mode=TwoWay}" />
                        <ToggleSwitch Header="Network adapter power"
                                      IsOn="{Binding NetworkPowerEnabled, Mode=TwoWay}" />
                        <ToggleSwitch Header="GPU power saving"
                                      IsOn="{Binding GpuPowerEnabled, Mode=TwoWay}" />
                        <ToggleSwitch Header="CPU core parking"
                                      IsOn="{Binding CpuParkingEnabled, Mode=TwoWay}" />
                        <ToggleSwitch Header="Disk idle coalescing"
                                      IsOn="{Binding DiskCoalescingEnabled, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Memory -->
            <StackPanel Spacing="8">
                <TextBlock Text="Memory" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel>
                            <TextBlock Text="Usage threshold (%)" Opacity="0.7" FontSize="12" />
                            <NumberBox Value="{Binding MemoryThresholdPercent, Mode=TwoWay}"
                                       Minimum="50" Maximum="99"
                                       SpinButtonPlacementMode="Inline"
                                       MinWidth="200" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Cooldown (seconds)" Opacity="0.7" FontSize="12" />
                            <NumberBox Value="{Binding MemoryCooldownSeconds, Mode=TwoWay}"
                                       Minimum="5" Maximum="600"
                                       SpinButtonPlacementMode="Inline"
                                       MinWidth="200" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Optimization level" Opacity="0.7" FontSize="12" />
                            <ComboBox ItemsSource="{Binding OptimizationLevels}"
                                      SelectedItem="{Binding OptimizationLevel, Mode=TwoWay}"
                                      MinWidth="200" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                <Button Content="Save"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsDirty}" />
                <Button Content="Reset to defaults"
                        Command="{Binding ResetCommand}" />
                <TextBlock VerticalAlignment="Center" Opacity="0.7"
                           Text="{Binding IsDirty, FallbackValue=''}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
