<Page
    x:Class="OptiSYS.Views.MemoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Optimize Button.IsEnabled inverts IsOptimizing via InvBoolToVis → that converter
        returns Visibility (not bool), so we use an explicit {Binding} with a plain NOT via
        an InverseBool-to-Bool converter pattern.  Simpler approach: bind Button.Command to
        OptimizeCommand (an AsyncRelayCommand) whose CanExecute returns !IsExecuting, and let
        WinUI auto-disable the button.  That keeps the XAML free of inverter gymnastics.
    -->
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Memory" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Usage card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Usage" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Border CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                Background="{Binding PressureLevel, Converter={StaticResource PressureBrush}}">
                            <TextBlock Text="{Binding PressureLevel}" Foreground="White" FontSize="12" />
                        </Border>
                    </StackPanel>
                    <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                               Text="{Binding MemoryInfo.UsagePercent, Converter={StaticResource Pct}}" />
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding MemoryInfo.UsagePercent, Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="16" Opacity="0.8">
                        <StackPanel>
                            <TextBlock Text="Total" Opacity="0.7" FontSize="11" />
                            <TextBlock Text="{Binding MemoryInfo.TotalPhysicalBytes, Converter={StaticResource Bytes}}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Used" Opacity="0.7" FontSize="11" />
                            <TextBlock Text="{Binding MemoryInfo.UsedBytes, Converter={StaticResource Bytes}}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Available" Opacity="0.7" FontSize="11" />
                            <TextBlock Text="{Binding MemoryInfo.AvailablePhysicalBytes, Converter={StaticResource Bytes}}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Optimize action -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <Button Content="Optimize memory"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding OptimizeCommand}" />
                <ProgressRing IsActive="{Binding IsOptimizing}"
                              Visibility="{Binding IsOptimizing, Converter={StaticResource BoolToVis}}"
                              Width="20" Height="20" />
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>

            <!-- Last result — always rendered so the layout doesn't jump on first optimize;
                 the placeholder text clears once a run completes.  (Visibility binding would
                 need a NonNullToVisibility converter, which we don't have yet.) -->
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Last optimization" Opacity="0.7" FontSize="12" />
                    <TextBlock Text="{Binding LastOptimizationResult, FallbackValue='(no optimization yet)', TargetNullValue='(no optimization yet)'}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
