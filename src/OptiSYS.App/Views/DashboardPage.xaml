<Page
    x:Class="OptiSYS.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <!--
        Bindings use {Binding …} (not x:Bind).  Rationale: x:Bind requires the VM type to be
        set as the Page's DataContext at compile time via a typed backing field, and the DI
        flow we use (ctor of the code-behind pulls the VM out of AppHost.Services at runtime)
        doesn't give the XAML compiler that typed anchor.  Classic {Binding} resolves off the
        runtime DataContext, which fits the pattern perfectly.
    -->
    <Grid Padding="24" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Dashboard"
                   Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Battery Card -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <StackPanel Spacing="8">
                <TextBlock Text="Battery" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                           Text="{Binding BatteryInfo.ChargePercent, Converter={StaticResource Pct}}" />
                <ProgressBar Minimum="0" Maximum="100"
                             Value="{Binding BatteryInfo.ChargePercent, Mode=OneWay}" />
                <TextBlock FontSize="12" Opacity="0.7"
                           Text="{Binding BatteryInfo.PowerSource}" />
            </StackPanel>
        </Border>

        <!-- Memory Card -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <StackPanel Spacing="8">
                <TextBlock Text="Memory" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Style="{StaticResource HeaderTextBlockStyle}"
                           Text="{Binding MemoryInfo.UsagePercent, Converter={StaticResource Pct}}" />
                <ProgressBar Minimum="0" Maximum="100"
                             Value="{Binding MemoryInfo.UsagePercent, Mode=OneWay}" />
                <TextBlock FontSize="12" Opacity="0.7">
                    <Run Text="{Binding MemoryInfo.UsedBytes, Converter={StaticResource Bytes}}" />
                    <Run Text=" of " />
                    <Run Text="{Binding MemoryInfo.TotalPhysicalBytes, Converter={StaticResource Bytes}}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Footer: Refresh -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       Opacity="0.7"
                       Text="{Binding StatusMessage}" />
            <Button Content="Refresh"
                    Command="{Binding RefreshCommand}" />
        </StackPanel>
    </Grid>
</Page>
