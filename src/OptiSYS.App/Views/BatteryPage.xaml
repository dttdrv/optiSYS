<Page
    x:Class="OptiSYS.Views.BatteryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        ToggleSwitch intentionally shows status only (IsEnabled=False).  Its IsOn is OneWay-
        bound to the VM's state flag.  The user triggers the actual toggle via the adjacent
        "Toggle" Button bound to the VM's Toggle{Name}Command — WinUI's ToggleSwitch has no
        Command property out of the box, and the VM's toggle is state-aware (Activate if off,
        Revert if on) so a separate trigger is cleaner than wiring a Toggled event handler.
    -->
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16" MaxWidth="920" HorizontalAlignment="Left">
            <TextBlock Text="Battery" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Status card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Charge" Opacity="0.7" FontSize="12" />
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                   Text="{Binding BatteryInfo.ChargePercent, Converter={StaticResource Pct}}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Drain" Opacity="0.7" FontSize="12" />
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                   Text="{Binding BatteryInfo.DrainRateDisplay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Time remaining" Opacity="0.7" FontSize="12" />
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                   Text="{Binding BatteryInfo.TimeRemainingDisplay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="Power and display" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="EcoQoS (power-efficient scheduler)" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding IsEcoqosActive, Mode=OneWay}" IsEnabled="False" />
                    <Button Grid.Column="2" Content="Toggle" Command="{Binding ToggleEcoqosCommand}" />
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Timer resolution (1ms → 15.6ms)" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding IsTimerResolutionActive, Mode=OneWay}" IsEnabled="False" />
                    <Button Grid.Column="2" Content="Toggle" Command="{Binding ToggleTimerResolutionCommand}" />
                </Grid>
            </StackPanel>

            <TextBlock Text="Background activity" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Background services throttle" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding IsBackgroundServicesActive, Mode=OneWay}" IsEnabled="False" />
                    <Button Grid.Column="2" Content="Toggle" Command="{Binding ToggleBackgroundServicesCommand}" />
                </Grid>
            </StackPanel>

            <TextBlock Text="Hardware power" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="USB selective suspend" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding IsUsbSuspendActive, Mode=OneWay}" IsEnabled="False" />
                    <Button Grid.Column="2" Content="Toggle" Command="{Binding ToggleUsbSuspendCommand}" />
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Network adapter power" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding IsNetworkPowerActive, Mode=OneWay}" IsEnabled="False" />
                    <Button Grid.Column="2" Content="Toggle" Command="{Binding ToggleNetworkPowerCommand}" />
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="GPU power saving" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding IsGpuPowerActive, Mode=OneWay}" IsEnabled="False" />
                    <Button Grid.Column="2" Content="Toggle" Command="{Binding ToggleGpuPowerCommand}" />
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CPU core parking" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding IsCpuParkingActive, Mode=OneWay}" IsEnabled="False" />
                    <Button Grid.Column="2" Content="Toggle" Command="{Binding ToggleCpuParkingCommand}" />
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Disk idle coalescing" VerticalAlignment="Center" />
                    <ToggleSwitch Grid.Column="1" IsOn="{Binding IsDiskCoalescingActive, Mode=OneWay}" IsEnabled="False" />
                    <Button Grid.Column="2" Content="Toggle" Command="{Binding ToggleDiskCoalescingCommand}" />
                </Grid>
            </StackPanel>

            <!-- Bulk actions -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                <Button Content="Activate all" Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding ActivateAllCommand}" />
                <Button Content="Revert all"
                        Command="{Binding RevertAllCommand}" />
                <Button Content="Refresh status"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
