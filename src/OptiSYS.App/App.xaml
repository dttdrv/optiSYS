<Application
    x:Class="OptiSYS.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- The app's accent brush, aliased to the live OS accent color. SystemAccentColor is a
                 built-in WinUI resource that tracks the system accent, so this brush follows the
                 user's Windows accent instead of a hardcoded colour. The opt-in brand-green accent
                 overrides this brush at runtime via ThemeManager.ApplyAccentColor. -->
            <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{ThemeResource SystemAccentColor}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
