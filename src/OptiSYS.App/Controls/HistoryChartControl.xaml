<UserControl
    x:Class="OptiSYS.Controls.HistoryChartControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="4">
        <Canvas x:Name="ChartCanvas" Height="100" HorizontalAlignment="Stretch" Background="Transparent" SizeChanged="OnCanvasSizeChanged">
            <!-- Subtle grid helper lines; X2 is stretched to the canvas width at redraw. -->
            <Line x:Name="GridLine1" X1="0" Y1="25" X2="0" Y2="25" Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" StrokeThickness="1" StrokeDashArray="3,3" />
            <Line x:Name="GridLine2" X1="0" Y1="50" X2="0" Y2="50" Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" StrokeThickness="1" StrokeDashArray="3,3" />
            <Line x:Name="GridLine3" X1="0" Y1="75" X2="0" Y2="75" Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" StrokeThickness="1" StrokeDashArray="3,3" />

            <!-- Gradient filled area underneath the line -->
            <Polygon x:Name="AreaPolygon" StrokeThickness="0" Opacity="0.15">
                <Polygon.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{ThemeResource SystemAccentColor}" Offset="0" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </Polygon.Fill>
            </Polygon>

            <!-- Line plot -->
            <Polyline x:Name="LinePolyline" Stroke="{ThemeResource SystemAccentColorBrush}" StrokeThickness="2.5" />
        </Canvas>
    </Border>
</UserControl>
