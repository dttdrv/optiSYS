<Window x:Class="OptiSYS.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="optiSYS Setup" 
        Height="480" 
        Width="680"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- Fluent Custom CheckBox Styling -->
        <Style x:Key="FluentCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F4F7F5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,8,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Border x:Name="BoxBorder" CornerRadius="4" BorderThickness="1.5" BorderBrush="#5CB865" Background="Transparent">
                                        <Grid x:Name="CheckIcon" Visibility="Collapsed">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="11" Foreground="#0D1114" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter VerticalAlignment="Center" />
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BoxBorder" Property="Background" Value="#5CB865" />
                                <Setter TargetName="BoxBorder" Property="BorderBrush" Value="#5CB865" />
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BoxBorder" Property="BorderBrush" Value="#7ED286" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fluent Primary Button Styling -->
        <Style x:Key="FluentPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#5CB865" />
            <Setter Property="Foreground" Value="#0D1114" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#7ED286" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#4C9C54" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fluent Secondary Button Styling -->
        <Style x:Key="FluentSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F4F7F5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#40554A" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#1AFFFFFF" />
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#605CB865" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#0FFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fluent Window Minimize/Close Buttons -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseChromeButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                </Trigger>
            </ControlTemplate.Triggers>
        </Style>

        <!-- Custom Progress Bar with Glowing Pulse -->
        <Style x:Key="FluentProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="Track" Background="{TemplateBinding Background}" CornerRadius="3" />
                            <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                <Grid>
                                    <Border x:Name="Indicator" CornerRadius="3">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#5CB865" Offset="0" />
                                                <GradientStop Color="#9AE2A1" Offset="0.5" />
                                                <GradientStop Color="#5CB865" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <!-- Inner Pulse Glow -->
                                    <Border CornerRadius="3" Opacity="0.5">
                                        <Border.Background>
                                            <LinearGradientBrush x:Name="PulseBrush" StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#00FFFFFF" Offset="0" />
                                                <GradientStop Color="#80FFFFFF" Offset="0.2" />
                                                <GradientStop Color="#00FFFFFF" Offset="0.4" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Decorator>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Continuous Pulse Animation -->
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <PointAnimation Storyboard.TargetName="PulseBrush" 
                                                        Storyboard.TargetProperty="StartPoint"
                                                        From="-1,0" To="1,0" Duration="0:0:1.5" />
                                        <PointAnimation Storyboard.TargetName="PulseBrush" 
                                                        Storyboard.TargetProperty="EndPoint"
                                                        From="0,0" To="2,0" Duration="0:0:1.5" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Drop Shadow & Content Border -->
    <Grid Margin="10">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.45" Color="#000000" />
        </Grid.Effect>
        
        <Border x:Name="WindowFrame" CornerRadius="12" BorderThickness="1.5" BorderBrush="#263E32" Background="#0C0F12" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Custom Title Bar -->
                    <RowDefinition Height="42" />
                    <!-- Main Body Content -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Acrylic/Glassmorphism Glow Accents (Static) -->
                <Grid IsHitTestVisible="False" Grid.RowSpan="2">
                    <!-- Top-Left green ambient spot -->
                    <Ellipse Width="350" Height="350" Fill="#105CB865" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-120,-120,0,0">
                        <Ellipse.Effect>
                            <BlurEffect Radius="90" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <!-- Bottom-Right secondary glow -->
                    <Ellipse Width="250" Height="250" Fill="#0A7ED286" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-80">
                        <Ellipse.Effect>
                            <BlurEffect Radius="70" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>

                <!-- Custom Header/TitleBar Grid -->
                <Grid Grid.Row="0" Background="#05FFFFFF" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <!-- Custom Icon Mark drawing using simple paths -->
                        <Path Data="M 7,0 A 7,7 0 1 1 7,14 A 7,7 0 0 1 7,0 Z M 7,3 L 7,11 M 3,7 L 11,7"
                              Stroke="#5CB865" StrokeThickness="1.8" Width="14" Height="14" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="45" />
                            </Path.RenderTransform>
                        </Path>
                        <TextBlock Text="optiSYS Setup" Foreground="#9AE2A1" FontSize="12.5" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- TitleBar Action Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="#F4F7F5" Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click" />
                        <Button Content="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="#F4F7F5" Style="{StaticResource CloseChromeButton}" Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>

                <!-- Step Panels Container with RenderTransforms for sliding transitions -->
                <Grid Grid.Row="1" Margin="32,8,32,32">
                    
                    <!-- ================= WELCOME SCREEN ================= -->
                    <Grid x:Name="WelcomePanel" Visibility="Visible" Opacity="1">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="WelcomeTransform" X="0" />
                        </Grid.RenderTransform>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Left / Right Layout for branding visual -->
                        <Grid Grid.Row="0" Margin="0,16,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <Border CornerRadius="8" Background="#141E19" BorderBrush="#2C4E3D" BorderThickness="1" HorizontalAlignment="Left" Padding="8,4" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#5CB865" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="OFFICIAL VERIFIED BUILD" FontSize="10" FontWeight="Bold" Foreground="#9AE2A1" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="WelcomeTitle" Text="Welcome to optiSYS" FontSize="28" FontWeight="Bold" Foreground="#F4F7F5" />
                                <TextBlock x:Name="WelcomeSubtitle" Text="Configure settings below to install the active system and runtime memory optimization suite." FontSize="14" Foreground="#9EAEA4" TextWrapping="Wrap" Margin="0,4,0,20" LineHeight="20" />
                                
                                <CheckBox x:Name="DesktopShortcutCheck" Content="Create Desktop Shortcut" Style="{StaticResource FluentCheckBox}" IsChecked="True" />
                                <CheckBox x:Name="StartMenuShortcutCheck" Content="Create Start Menu Shortcut" Style="{StaticResource FluentCheckBox}" IsChecked="True" />
                                <CheckBox x:Name="StartWithWindowsCheck" Content="Start optiSYS with Windows" Style="{StaticResource FluentCheckBox}" IsChecked="True" />
                            </StackPanel>

                            <!-- Right-side brand emblem panel -->
                            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="180" Height="180">
                                <Border CornerRadius="90" Background="#06FFFFFF" BorderBrush="#105CB865" BorderThickness="1.5">
                                    <Grid>
                                        <!-- Ambient inner logo glow -->
                                        <Ellipse Fill="#055CB865" Margin="20" />
                                        
                                        <!-- Leaf symbol drawn with nested shapes -->
                                        <Path Data="M 90,40 C 65,40 50,65 50,90 C 50,115 65,140 90,140 C 115,140 130,115 130,90 C 130,65 115,40 90,40 Z Z M 90,40 L 90,140" 
                                              Fill="#155CB865" Stroke="#5CB865" StrokeThickness="3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        
                                        <!-- Arrow overlay -->
                                        <Path Data="M 120,50 L 135,65 L 115,68 Z" Fill="#5CB865" />
                                        <Ellipse Width="16" Height="16" Fill="#F4F7F5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Ellipse Width="8" Height="8" Fill="#0D1114" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="Installer will be saved to Local AppData" Foreground="#6C7F73" FontSize="11" VerticalAlignment="Center" />
                            
                            <Button x:Name="InstallButton" Grid.Column="1" Content="Install Now" Style="{StaticResource FluentPrimaryButton}" Click="InstallButton_Click" />
                        </Grid>
                    </Grid>

                    <!-- ================= INSTALLING SCREEN ================= -->
                    <Grid x:Name="InstallingPanel" Visibility="Collapsed" Opacity="0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="InstallingTransform" X="150" />
                        </Grid.RenderTransform>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="ProgressTitle" Text="Installing optiSYS" FontSize="24" FontWeight="Bold" Foreground="#F4F7F5" Margin="0,0,0,8" />
                            <TextBlock x:Name="ProgressSub" Text="Preparing installation environment..." FontSize="13" Foreground="#9EAEA4" Margin="0,0,0,32" />
                            
                            <ProgressBar x:Name="InstallProgress" Style="{StaticResource FluentProgressBar}" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,16" />
                            
                            <TextBlock x:Name="ProgressStatus" Text="Extracting resources..." Foreground="#6C7F73" FontSize="11.5" />
                        </StackPanel>
                    </Grid>

                    <!-- ================= COMPLETED SCREEN ================= -->
                    <Grid x:Name="CompletedPanel" Visibility="Collapsed" Opacity="0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="CompletedTransform" X="150" />
                        </Grid.RenderTransform>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,32,0,0">
                            <!-- Success green check banner -->
                            <Grid Width="70" Height="70" Margin="0,0,0,24">
                                <Ellipse Fill="#155CB865" Stroke="#5CB865" StrokeThickness="2" />
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" FontSize="32" Foreground="#5CB865" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                            </Grid>
                            
                            <TextBlock x:Name="FinishedTitle" Text="Success! Installation Complete" FontSize="26" FontWeight="Bold" Foreground="#F4F7F5" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock x:Name="FinishedSub" Text="optiSYS has been successfully configured and installed." FontSize="14.5" Foreground="#9EAEA4" HorizontalAlignment="Center" Margin="0,0,0,24" />

                            <CheckBox x:Name="LaunchAfterFinishCheck" Content="Launch optiSYS now" Style="{StaticResource FluentCheckBox}" IsChecked="True" HorizontalAlignment="Center" />
                        </StackPanel>

                        <Button x:Name="FinishButton" Grid.Row="1" Content="Finish" HorizontalAlignment="Right" Style="{StaticResource FluentPrimaryButton}" Width="120" Click="FinishButton_Click" />
                    </Grid>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
